# HCV Airflow — environment variables for Portainer deployment.
#
# Copy to .env and fill in the values, or set directly in Portainer.

# ── Stack identity ───────────────────────────────────────────────────────────
STACK_NAME=hcv-airflow-training
AIRFLOW_UID=1000

# ── Custom Airflow image (with ODBC drivers + pandas) ────────────────────────
AIRFLOW_IMAGE_NAME=ghcr.io/hcv-dev/hcv-airflow:training

# ── DAGs repository (auto-synced by the git-sync sidecar) ───────────────────
# GitHub credentials for private repo access (PAT needs "repo" or "contents:read" scope)
DAGS_GIT_USER=
DAGS_GIT_PAT=
DAGS_REPO_URL=https://github.com/HCV-Dev/hcv-airflow-dags.git
DAGS_REPO_BRANCH=training
# DAGS_SYNC_INTERVAL=60

# ── Admin credentials ────────────────────────────────────────────────────────
AIRFLOW_ADMIN_PASSWORD=change-me

# ── Fernet key (encrypts connection passwords stored in metadata DB) ─────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── API secret key (JWT signing for API server ↔ worker auth) ────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_SECRET_KEY=

# ── HCV database connections ─────────────────────────────────────────────────
# ICU SQL Server — Airflow JSON connection with ODBC string in extra
HCV_ICU_CONN_STRING='{"conn_type": "generic", "extra": {"odbc_connect": "DRIVER={ODBC Driver 18 for SQL Server};SERVER=srv;DATABASE=db;UID=webapp;PWD=secret;Encrypt=no;TrustServerCertificate=yes"}}'

# Reporting PostgreSQL
HCV_REPORTING_DB_URL=postgresql://hcv_reporting:password@hcv-reporting-training-db:5432/hcv_reporting

# ── Ports ────────────────────────────────────────────────────────────────────
AIRFLOW_PORT=8081

# ── SMTP (SendGrid in prod) ──────────────────────────────────────────────────
# Prod defaults to SendGrid (smtp.sendgrid.net:587, STARTTLS). The only value
# you must supply is the API key; the rest have sensible defaults.
SENDGRID_API_KEY=
# SMTP_FROM=airflow@hcv.co.za
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
